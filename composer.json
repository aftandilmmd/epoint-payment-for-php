{
    "name": "aftandilmmd/epoint-payment-for-php",
    "description": "Epoint.az payment gateway integration for PHP.",
    "keywords": ["php", "payment", "epoint", "gateway", "azerbaijan"],
    "license": "MIT",
    "authors": [
        {
            "name": "Aftandil",
            "email": "aftandil.mmd@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "guzzlehttp/guzzle": "^7.0",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "pestphp/pest": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Aftandilmmd\\EpointPayment\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Aftandilmmd\\EpointPayment\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}
